# === LLM 백엔드 설정 ===
# 우선순위: (1) LLM_* 범용  →  (2) OPENAI_*  →  (3) 로컬 Ollama

# (1) 임의의 OpenAI 호환 제공자 — 무료 LLM 권장 (Gemini, Groq 등)
#  · Google Gemini (무료): LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#                          LLM_MODEL=gemini-2.0-flash
#  · Groq (무료):          LLM_BASE_URL=https://api.groq.com/openai/v1
#                          LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# (2) OpenAI (유료)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# (3) 위가 모두 비어 있으면 로컬 Ollama로 폴백
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=exaone3.5:7.8b

# 서버 포트 (호스팅이 자동 주입하면 비워 두세요)
# PORT=3000

# === 평가서 영구 저장 (Postgres: Neon 등) ===
# DATABASE_URL이 있으면 Postgres에 영구 저장, 없으면 로컬 파일(임시)로 폴백합니다.
# 예: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=
