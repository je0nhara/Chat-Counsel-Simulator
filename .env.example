# === LLM 백엔드 설정 ===
# OpenAI를 사용하려면 키를 입력하세요 (배포 시 권장)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OPENAI_API_KEY가 비어 있으면 아래 로컬 Ollama로 자동 폴백합니다
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=exaone3.5:7.8b

# 서버 포트 (호스팅이 자동 주입하면 비워 두세요)
# PORT=3000

# === 평가서 영구 저장 (MongoDB) ===
# MONGODB_URI가 있으면 MongoDB에 영구 저장, 없으면 로컬 파일(임시)로 폴백합니다.
# 예: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
